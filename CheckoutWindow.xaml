<Window x:Class="GestoreOrdini.CheckoutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Checkout"
        Width="960"
        Height="700"
        MinWidth="880"
        MinHeight="620"
        Background="#FFEDE7EA">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Checkout"
                   FontFamily="Speedee"
                   FontSize="44"
                   FontWeight="Bold"
                   Margin="0,0,0,14"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1.2*"/>
            </Grid.ColumnDefinitions>

            <Border Background="White" CornerRadius="10" BorderBrush="#22000000" BorderThickness="1" Padding="12" Margin="0,0,12,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="Prodotti nel carrello"
                               FontFamily="Speedee"
                               FontSize="28"
                               FontWeight="Bold"
                               Margin="0,0,0,10"/>
                    <DataGrid ItemsSource="{Binding CheckoutItems}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              RowHeight="42">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Prodotto" Binding="{Binding ProductName}" Width="*"/>
                            <DataGridTextColumn Header="Qtà" Binding="{Binding Quantity}" Width="70"/>
                            <DataGridTextColumn Header="Prezzo" Binding="{Binding PriceText}" Width="180"/>
                            <DataGridTextColumn Header="Totale" Binding="{Binding LineTotal, StringFormat={}{0:C}}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <Border Grid.Column="1" Background="White" CornerRadius="10" BorderBrush="#22000000" BorderThickness="1" Padding="14">
                <StackPanel>
                    <TextBlock Text="Dati pagamento"
                               FontFamily="Speedee"
                               FontSize="28"
                               FontWeight="Bold"
                               Margin="0,0,0,10"/>

                    <TextBlock Text="Intestatario carta" FontFamily="Speedee" FontSize="18" Margin="0,0,0,4"/>
                    <TextBox x:Name="CardholderTextBox" Height="38" Margin="0,0,0,10" FontSize="16"/>

                    <TextBlock Text="Numero carta" FontFamily="Speedee" FontSize="18" Margin="0,0,0,4"/>
                    <TextBox x:Name="CardNumberTextBox" Height="38" Margin="0,0,0,10" FontSize="16"/>

                    <TextBlock Text="Scadenza (MM/AA)" FontFamily="Speedee" FontSize="18" Margin="0,0,0,4"/>
                    <TextBox x:Name="ExpirationTextBox" Height="38" Margin="0,0,0,10" FontSize="16"/>

                    <TextBlock Text="CVV" FontFamily="Speedee" FontSize="18" Margin="0,0,0,4"/>
                    <TextBox x:Name="CvvTextBox" Height="38" Margin="0,0,0,14" FontSize="16"/>

                    <Border Background="#FFF8F8F8" BorderBrush="#22000000" BorderThickness="1" CornerRadius="8" Padding="10">
                        <StackPanel>
                            <TextBlock Text="Totale ordine" FontFamily="Speedee" FontSize="20"/>
                            <TextBlock Text="{Binding TotalFormatted}" FontFamily="Speedee" FontSize="34" FontWeight="Bold" Foreground="#FFE4002B"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Annulla"
                    Width="130"
                    Height="44"
                    Margin="0,0,8,0"
                    FontFamily="Speedee"
                    FontSize="20"
                    Click="CancelButton_Click"/>

            <Button Content="Paga"
                    Width="150"
                    Height="44"
                    FontFamily="Speedee"
                    FontSize="22"
                    FontWeight="Bold"
                    Background="#FFBC0D"
                    BorderThickness="0"
                    Click="PayButton_Click"/>
        </StackPanel>
    </Grid>
</Window>

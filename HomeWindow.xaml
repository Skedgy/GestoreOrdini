<Window x:Class="GestoreOrdini.HomeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:svg="http://sharpvectors.codeplex.com/svgc/"
        mc:Ignorable="d"
        Title="Home"
        WindowState="Maximized"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        WindowStartupLocation="CenterScreen"
        Height="600"
        Width="1000"
        MinHeight="600"
        MinWidth="1000"
        Background="#FFEDE7EA">
    <Grid>
        <Grid.Resources>
            <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="Speedee"/>
                <Setter Property="FontSize" Value="36"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Foreground" Value="#FF2B2929"/>
            </Style>

            <Style x:Key="MenuCardStyle" TargetType="Border">
                <Setter Property="Background" Value="White"/>
                <Setter Property="CornerRadius" Value="14"/>
                <Setter Property="BorderBrush" Value="#12000000"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Margin" Value="0,0,14,14"/>
            </Style>

            <Style x:Key="CategoryChipStyle" TargetType="Button">
                <Setter Property="Background" Value="#FFF7F7F7"/>
                <Setter Property="BorderBrush" Value="#22000000"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="14,8"/>
                <Setter Property="Margin" Value="0,0,8,8"/>
                <Setter Property="FontFamily" Value="Speedee"/>
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="20">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#FFFFF4CC"/>
                        <Setter Property="BorderBrush" Value="#55FFBC0D"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="TopNavItemStyle" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="Speedee"/>
                <Setter Property="FontSize" Value="24"/>
                <Setter Property="Foreground" Value="#FF222222"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>

            <Style x:Key="CreditsButtonStyle" TargetType="Button">
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Padding" Value="18,8"/>
                <Setter Property="Margin" Value="24,0,0,0"/>
                <Setter Property="FontFamily" Value="Speedee"/>
                <Setter Property="FontSize" Value="22"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Foreground" Value="#FF1E1E1E"/>
                <Setter Property="Background">
                    <Setter.Value>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#FFFFE07A" Offset="0"/>
                            <GradientStop Color="#FFFFBC0D" Offset="1"/>
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="16">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Opacity" Value="0.9"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="LogoutButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="FontFamily" Value="Speedee"/>
                <Setter Property="FontSize" Value="20"/>
                <Setter Property="Foreground" Value="#FF000000"/>
                <Setter Property="Padding" Value="0"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Foreground" Value="#FFBC0D"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="DropDownMenuItemButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="10,8"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                <Setter Property="FontFamily" Value="Speedee"/>
                <Setter Property="FontSize" Value="22"/>
                <Setter Property="Foreground" Value="#FF222222"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#FFFFF4CC"/>
                        <Setter Property="Foreground" Value="#FFB8860B"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="DownloadButtonStyle" TargetType="Button">
                <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                <Setter Property="RenderTransform">
                    <Setter.Value>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <EventTrigger RoutedEvent="MouseEnter">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                 To="1.05"
                                                 Duration="0:0:0.15"/>
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                 To="1.05"
                                                 Duration="0:0:0.15"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                    <EventTrigger RoutedEvent="MouseLeave">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                 To="1"
                                                 Duration="0:0:0.15"/>
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                 To="1"
                                                 Duration="0:0:0.15"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="SocialButtonStyle" TargetType="Button">
                <Setter Property="Width" Value="46"/>
                <Setter Property="Height" Value="46"/>
                <Setter Property="Background" Value="#FFBC0D"/>
                <Setter Property="Foreground" Value="#FF1E1E1E"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="FontFamily" Value="Speedee"/>
                <Setter Property="FontSize" Value="20"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="23">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#FFE6A90B"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="AddToCartButtonStyle" TargetType="Button">
                <Setter Property="Width" Value="88"/>
                <Setter Property="Height" Value="36"/>
                <Setter Property="Background" Value="White"/>
                <Setter Property="Foreground" Value="#FF1E1E1E"/>
                <Setter Property="BorderBrush" Value="#33000000"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="FontFamily" Value="Speedee"/>
                <Setter Property="FontSize" Value="20"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsAdded}" Value="True">
                        <Setter Property="Background" Value="#FFFFBC0D"/>
                        <Setter Property="BorderBrush" Value="#FFFFBC0D"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="QuantityStepperButtonStyle" TargetType="Button">
                <Setter Property="Width" Value="30"/>
                <Setter Property="Height" Value="34"/>
                <Setter Property="Background" Value="#FFF5F5F5"/>
                <Setter Property="BorderBrush" Value="#33000000"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="FontFamily" Value="Speedee"/>
                <Setter Property="FontSize" Value="20"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#FFFFF4CC"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#FFF6F6F6"
                BorderBrush="#22FFBC0D"
                BorderThickness="0,0,0,1"
                Padding="14,10,14,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Width="68"
                        Height="68"
                        Background="#FF235036"
                        CornerRadius="8"
                        VerticalAlignment="Center">
                    <svg:SvgViewbox Source="/Images/McDonald's_Golden_Arches.svg"
                                    Width="44"
                                    Height="40"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"/>
                </Border>

                <ScrollViewer Grid.Column="1"
                              Margin="20,0,0,0"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <ToggleButton x:Name="MenusDropDownButton"
                                      Padding="0"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      Cursor="Hand"
                                      VerticalAlignment="Center">
                            <StackPanel>
                                <TextBlock Text="I nostri menù"
                                           FontFamily="Speedee"
                                           FontSize="26"
                                           FontWeight="Bold"
                                           Foreground="#FF1E1E1E"/>
                                <Border Height="4"
                                        Width="145"
                                        Margin="0,6,0,0"
                                        Background="#FFBC0D"/>
                            </StackPanel>
                        </ToggleButton>

                        <Button x:Name="CreditsTopButton"
                                Content="Crediti"
                                Style="{StaticResource CreditsButtonStyle}"/>

                        <Button x:Name="OrdersReportTopButton"
                                Content="Resoconto Ordini"
                                Style="{StaticResource CreditsButtonStyle}"/>
                    </StackPanel>
                </ScrollViewer>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button x:Name="CartButton"
                            Width="48"
                            Height="48"
                            Margin="0,0,16,0"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            VerticalAlignment="Center">
                        <Grid>
                            <svg:SvgViewbox Source="/Images/Cart.svg" Width="26" Height="26"/>
                            <Border Background="#FFFFBC0D"
                                    BorderBrush="#FF1E1E1E"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Width="20"
                                    Height="20"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Margin="0,-4,-4,0">
                                <TextBlock x:Name="CartCountText"
                                           Text="0"
                                           FontFamily="Speedee"
                                           FontSize="12"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Button>

                    <StackPanel Margin="0,0,18,0"
                                VerticalAlignment="Center">
                        <TextBlock x:Name="UtenteNomeCognomeText"
                                   FontFamily="Speedee"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="#FF1E1E1E"
                                   Text="Utente"/>
                        <TextBlock x:Name="UtentePosizioneText"
                                   FontFamily="Speedee"
                                   FontSize="15"
                                   Foreground="#AA1E1E1E"
                                   Text="Posizione non disponibile"/>
                    </StackPanel>

                    <Button x:Name="LogoutButton"
                            Content="Logout"
                            Style="{StaticResource LogoutButtonStyle}"
                            VerticalAlignment="Center"/>
                </StackPanel>

                <Popup PlacementTarget="{Binding ElementName=MenusDropDownButton}"
                       Placement="Bottom"
                       VerticalOffset="12"
                       AllowsTransparency="True"
                       IsOpen="{Binding IsChecked, ElementName=MenusDropDownButton}"
                       StaysOpen="False"
                       PopupAnimation="Fade">
                    <Border Width="360"
                            Background="White"
                            BorderBrush="#19000000"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="14,12,14,14">
                        <StackPanel>
                            <TextBlock Text="I nostri menù"
                                       FontFamily="Speedee"
                                       FontSize="26"
                                       FontWeight="Bold"
                                       Foreground="#FF1E1E1E"
                                       Margin="2,0,0,8"/>

                            <Border Height="2"
                                    Background="#FFBC0D"
                                    Margin="0,0,0,8"/>

                            <Button Style="{StaticResource DropDownMenuItemButtonStyle}" Content="McBacon" Tag="McBacon" Click="MenuCategoryButton_Click"/>
                            <Button Style="{StaticResource DropDownMenuItemButtonStyle}" Content="McWrap" Tag="McWrap" Click="MenuCategoryButton_Click"/>
                            <Button Style="{StaticResource DropDownMenuItemButtonStyle}" Content="McChicken" Tag="McChicken" Click="MenuCategoryButton_Click"/>
                            <Button Style="{StaticResource DropDownMenuItemButtonStyle}" Content="Insalate" Tag="Insalate" Click="MenuCategoryButton_Click"/>
                            <Button Style="{StaticResource DropDownMenuItemButtonStyle}" Content="Altri" Tag="Altri" Click="MenuCategoryButton_Click"/>
                        </StackPanel>
                    </Border>
                </Popup>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Background="#FFEDE7EA"
                Padding="30">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock x:Name="WelcomeMessageText"
                           Grid.Row="0"
                           FontFamily="Speedee"
                           FontSize="44"
                           FontWeight="Bold"
                           Foreground="#FF2B2929"
                           TextAlignment="Center"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"
                           MaxWidth="980"
                           Margin="0,0,0,12"
                           Text="Benvenuto!&#x0a;Per iniziare a navigare i nostri menù apri il menù a tendina!"/>

                <TextBlock x:Name="MenuCategoryTitleText"
                           Grid.Row="1"
                           FontFamily="Speedee"
                           FontSize="34"
                           FontWeight="Bold"
                           Foreground="#FF2B2929"
                           Margin="0,0,0,12"
                           Text="Menù McBacon"
                           Visibility="Collapsed"/>

                <Grid Grid.Row="2" x:Name="MenuContentGrid" Visibility="Collapsed">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl x:Name="MenuCardsItemsControl"
                                      ItemsSource="{Binding MenuCards, RelativeSource={RelativeSource AncestorType=Window}}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource MenuCardStyle}" Width="280" Height="390">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="190"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <Image Grid.Row="0"
                                                   Source="{Binding ImagePath}"
                                                   Stretch="Uniform"
                                                   Margin="8"/>

                                            <StackPanel Grid.Row="1" Margin="12,10,12,12">
                                                <TextBlock Text="{Binding Title}"
                                                           FontFamily="Speedee"
                                                           FontSize="24"
                                                           FontWeight="Bold"
                                                           TextWrapping="Wrap"
                                                           TextTrimming="CharacterEllipsis"
                                                           Height="52"/>
                                                <TextBlock Text="{Binding Price}"
                                                           FontFamily="Speedee"
                                                           FontSize="19"
                                                           Foreground="{Binding PriceBrush}"
                                                           FontWeight="Bold"
                                                           Margin="0,6,0,0"/>

                                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                                    <Button Content="-"
                                                            Style="{StaticResource QuantityStepperButtonStyle}"
                                                            Tag="{Binding}"
                                                            Click="QuantityMinusButton_Click"
                                                            Margin="0,0,6,0"/>
                                                    <ComboBox Width="72"
                                                              Height="34"
                                                              Margin="0,0,6,0"
                                                              ItemsSource="{Binding Quantities}"
                                                              SelectedItem="{Binding SelectedQuantity, Mode=TwoWay}"
                                                              FontFamily="Speedee"
                                                              FontSize="16"/>
                                                    <Button Content="+"
                                                            Style="{StaticResource QuantityStepperButtonStyle}"
                                                            Tag="{Binding}"
                                                            Click="QuantityPlusButton_Click"
                                                            Margin="0,0,8,0"/>
                                                    <Button Content="ADD"
                                                            Style="{StaticResource AddToCartButtonStyle}"
                                                            Tag="{Binding}"
                                                            Click="AddToCartButton_Click"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <TextBlock x:Name="NoMenusText"
                               Visibility="Collapsed"
                               FontFamily="Speedee"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="#AA2B2929"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Text="Nessun menù disponibile per questa sezione."/>
                </Grid>

                <Border x:Name="CreditsDisclaimerPanel"
                        Grid.RowSpan="3"
                        Visibility="Collapsed"
                        Background="#CC000000"
                        Panel.ZIndex="20">
                    <Border HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Width="920"
                            MaxWidth="920"
                            Padding="24"
                            Background="#FFF8F8F8"
                            CornerRadius="14"
                            BorderBrush="#22000000"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Disclaimer legale"
                                       FontFamily="Speedee"
                                       FontSize="38"
                                       FontWeight="Bold"
                                       Margin="0,0,0,12"/>

                            <TextBlock FontFamily="Speedee"
                                       FontSize="24"
                                       TextWrapping="Wrap"
                                       LineHeight="34">
                                <Run Text="Questo è un progetto scolastico a scopo didattico prodotto da "/>
                                <Run Text="Kevin Polizzi" TextDecorations="Underline">
                                    <Run.Foreground>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#FF8B0000" Offset="0"/>
                                            <GradientStop Color="#FFDC143C" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Run.Foreground>
                                </Run>
                                <Run Text=" per l’"/>
                                <Run Text="ITIS Q. SELLA">
                                    <Run.Foreground>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#FF0D6EFD" Offset="0"/>
                                            <GradientStop Color="#FF00C2FF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Run.Foreground>
                                </Run>
                                <Run Text=". Questo progetto WPF intende soltanto simulare un'app dell'azienda "/>
                                <Run Text="McDonald’s">
                                    <Run.Foreground>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#FFE4002B" Offset="0"/>
                                            <GradientStop Color="#FFFFBC0D" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Run.Foreground>
                                </Run>
                                <Run Text=". Sede principale McDonald’s Corporation: 110 N Carpenter St, Chicago, IL 60607, USA. Io non possiedo alcun diritto sui marchi, loghi, contenuti o proprietà intellettuale riconducibili a McDonald’s."/>
                            </TextBlock>

                            <Button x:Name="CreditsCloseButton"
                                    Content="Chiudi"
                                    Width="150"
                                    Height="46"
                                    Margin="0,16,0,0"
                                    HorizontalAlignment="Right"
                                    FontFamily="Speedee"
                                    FontSize="22"
                                    FontWeight="Bold"
                                    Background="#FFBC0D"
                                    BorderThickness="0"
                                    Cursor="Hand"/>
                        </StackPanel>
                    </Border>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Background="#FFE6E6E6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="#FFBC0D"
                        Padding="28,22,28,22">
                    <StackPanel>
                        <WrapPanel>
                            <Border Width="112"
                                    Height="112"
                                    Background="#FFF3F3F3"
                                    CornerRadius="20"
                                    VerticalAlignment="Center"
                                    Margin="0,0,22,12">
                                <svg:SvgViewbox Source="/Images/McDonald's_Golden_Arches.svg"
                                                Width="64"
                                                Height="58"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"/>
                            </Border>

                            <StackPanel Width="920" Margin="0,0,20,12">
                                <TextBlock Text="Scarica la nostra APP"
                                           FontFamily="Speedee"
                                           FontSize="38"
                                           FontWeight="Bold"
                                           Foreground="#FF1F2430"/>
                                <TextBlock Text="Non perdere neanche un'offerta. Con la nostra App scopri ogni giorno tante sorprese pensate per te."
                                           FontFamily="Speedee"
                                           FontSize="20"
                                           Foreground="#FF1F2430"
                                           TextWrapping="Wrap"
                                           Margin="0,2,0,0"/>
                            </StackPanel>

                        </WrapPanel>

                        <WrapPanel Margin="0,2,0,0">
                            <Button Width="180"
                                    Height="54"
                                    Padding="0"
                                    Margin="0,0,10,0"
                                    BorderThickness="0"
                                    Background="Transparent"
                                    Cursor="Hand"
                                    Style="{StaticResource DownloadButtonStyle}"
                                    Click="AppStoreButton_Click">
                                <svg:SvgViewbox Source="/Images/Appstore.svg"/>
                            </Button>

                            <Button Width="180"
                                    Height="54"
                                    Padding="0"
                                    BorderThickness="0"
                                    Background="Transparent"
                                    Cursor="Hand"
                                    Style="{StaticResource DownloadButtonStyle}"
                                    Click="GooglePlayButton_Click">
                                <svg:SvgViewbox Source="/Images/GooglePlay.svg"/>
                            </Button>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Padding="0,22,0,22" Background="#FFE6E6E6">
                    <WrapPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="Seguici su"
                                   FontFamily="Speedee"
                                   FontSize="44"
                                   FontWeight="Bold"
                                   Foreground="#FF1F2430"
                                   Margin="0,0,18,0"
                                   VerticalAlignment="Center"/>

                        <Button Style="{StaticResource SocialButtonStyle}" Tag="https://www.tiktok.com/@mcdonaldsitalia" Click="SocialButton_Click" Margin="0,0,8,0">
                            <svg:SvgViewbox Source="/Images/SocialTikTok.svg" Width="22" Height="22"/>
                        </Button>
                        <Button Style="{StaticResource SocialButtonStyle}" Tag="https://www.instagram.com/mcdonaldsitalia/" Click="SocialButton_Click" Margin="0,0,8,0">
                            <svg:SvgViewbox Source="/Images/SocialInstagram.svg" Width="22" Height="22"/>
                        </Button>
                        <Button Style="{StaticResource SocialButtonStyle}" Tag="https://www.facebook.com/McDonaldsItalia" Click="SocialButton_Click" Margin="0,0,8,0">
                            <svg:SvgViewbox Source="/Images/SocialFacebook.svg" Width="22" Height="22"/>
                        </Button>
                        <Button Style="{StaticResource SocialButtonStyle}" Tag="https://www.youtube.com/user/mcdonaldsitalia" Click="SocialButton_Click">
                            <svg:SvgViewbox Source="/Images/SocialYouTube.svg" Width="22" Height="22"/>
                        </Button>
                    </WrapPanel>
                </Border>

                <Border Grid.Row="2" Background="#FFE6E6E6" Padding="0,4,0,26">
                    <TextBlock Text="Copyright © 2026 McDonald's. All rights reserved."
                               FontFamily="Speedee"
                               FontSize="20"
                               Foreground="#AA1F2430"
                               HorizontalAlignment="Center"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>

<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
  </PropertyGroup>

  <ItemGroup>
    <None Remove="Fonts\Speedee-Regular.otf" />
    <None Remove="Gifs\LoadingWB.gif" />
    <None Remove="Images\Appstore.svg" />
    <None Remove="Images\GooglePlay.svg" />
    <None Remove="Images\Cart.svg" />
    <None Remove="Images\McDonald%27s_Golden_Arches.svg" />
    <None Remove="Images\Menu.png" />
    <None Remove="Images\SocialFacebook.svg" />
    <None Remove="Images\SocialInstagram.svg" />
    <None Remove="Images\SocialTikTok.svg" />
    <None Remove="Images\SocialYouTube.svg" />
    <None Remove="Offers\9 Chicken McNuggets.png" />
    <None Remove="Offers\Double Chicken BBQ Menu.png" />
    <None Remove="Offers\McChicken Menu e 6 Chicken McNuggets.png" />
    <None Remove="Offers\McChicken Menu Large.png" />
    <None Remove="Offers\McFlurry.png" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="XamlAnimatedGif" Version="2.2.0" />
    <PackageReference Include="SharpVectors" Version="1.8.5" />
    <PackageReference Include="Svg" Version="3.4.7" />
  </ItemGroup>

  <ItemGroup>
    <Resource Include="Gifs\LoadingWB.gif" />

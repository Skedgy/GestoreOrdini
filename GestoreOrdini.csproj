    <Resource Include="Images\McDonald's_Golden_Arches.svg" />
    <Resource Include="Images\SocialFacebook.svg" />
    <Resource Include="Images\SocialInstagram.svg" />
    <Resource Include="Images\SocialTikTok.svg" />
    <Resource Include="Images\SocialYouTube.svg" />
  </ItemGroup>

  <ItemGroup>
    <Resource Include="Fonts\Speedee-Regular.otf" />
    <Resource Include="Images\Menu.png" />
    <Resource Include="Offers\9 Chicken McNuggets.png" />
    <Resource Include="Offers\Double Chicken BBQ Menu.png" />
    <Resource Include="Offers\McChicken Menu e 6 Chicken McNuggets.png" />
    <Resource Include="Offers\McChicken Menu Large.png" />
    <Resource Include="Offers\McFlurry.png" />
  </ItemGroup>

  <ItemGroup>
    <Folder Include="McBacon\" />
    <Folder Include="Altri\" />
    <Folder Include="McChicken\" />
    <Folder Include="McWrap\" />
